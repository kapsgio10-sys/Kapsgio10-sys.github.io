  <script>
    const ADMIN_EMAIL = "kapsgio10@gmail.com";

    let products = [];
    let priceData = {};

    async function loadData() {
      try {
        const [productsResponse, pricesResponse] = await Promise.all([
          fetch("./products.json?ts=" + Date.now()),
          fetch("./prices.json?ts=" + Date.now())
        ]);

        const productsJson = await productsResponse.json();
        const pricesJson = await pricesResponse.json();

        products = productsJson.products || [];
        priceData = pricesJson.prices || {};

        const updated = document.getElementById("lastUpdated");
        if (updated) {
          updated.textContent = "Τελευταία ενημέρωση τιμών: " + (pricesJson.updated_at || "Δεν υπάρχει ακόμα");
        }

        renderProducts();
      } catch (error) {
        console.error("Δεν φορτώθηκαν τα δεδομένα:", error);
        document.getElementById("productGrid").innerHTML = `
          <div class="bg-white border border-red-200 rounded-[2rem] p-8 text-red-700 col-span-full">
            <h3 class="text-xl font-black mb-2">Υπήρξε ένα πρόβλημα σύνδεσης</h3>
            <p>Δεν μπορέσαμε να φορτώσουμε τα προϊόντα αυτή τη στιγμή. Παρακαλώ ανανεώστε τη σελίδα ή δοκιμάστε ξανά αργότερα.</p>
          </div>
        `;
      }
    }

    function getPriceInfo(productId) {
      return priceData[productId] || {
        price: "Δεν υπάρχει διαθέσιμη τιμή",
        store: "-",
        status: "missing"
      };
    }

    function renderProducts() {
      const query = document.getElementById("searchInput").value.toLowerCase().trim();
      const category = document.getElementById("categoryFilter").value;
      const store = document.getElementById("storeFilter").value;

      const filtered = products.filter(product => {
        const text = [product.title, product.category, product.description, product.store].join(" ").toLowerCase();
        const matchesSearch = !query || text.includes(query);
        const matchesCategory = category === "all" || (product.category && product.category.toLowerCase() === category.toLowerCase());
        const matchesStore = store === "all" || (product.store && product.store.toLowerCase() === store.toLowerCase());
        return matchesSearch && matchesCategory && matchesStore;
      });

      const grid = document.getElementById("productGrid");
      const noProducts = document.getElementById("noProducts");

      grid.innerHTML = "";
      noProducts.classList.toggle("hidden", filtered.length !== 0);

      filtered.forEach(product => {
        const info = getPriceInfo(product.id);

        const card = document.createElement("article");
        card.className = "bg-white rounded-[2rem] p-6 border border-slate-200 soft-shadow card-hover";

        card.innerHTML = `
          <img src="${product.image}" alt="${product.title}" class="h-44 w-full object-cover rounded-3xl mb-5">
          <p class="text-blue-600 text-xs font-black uppercase tracking-widest">${product.category}</p>
          <h3 class="text-2xl font-black mt-2">${product.title}</h3>
          <p class="text-slate-600 mt-3">${product.description}</p>

          <div class="mt-5 rounded-2xl bg-slate-100 p-4">
            <p class="text-xs text-slate-500 mb-1">Τρέχουσα τιμή / Διαθεσιμότητα</p>
            <p class="text-base font-bold text-slate-800 leading-tight">${info.price}</p>
            <p class="text-xs text-slate-500 mt-2 border-t border-slate-200 pt-2">Πηγή: ${info.store || product.store}</p>
          </div>

          <a
            target="_blank"
            rel="noopener"
            href="${product.affiliate_url}"
            class="mt-5 block w-full bg-slate-950 text-white rounded-2xl px-5 py-3 font-black text-center"
          >
            Δες επιλογές
          </a>
        `;

        grid.appendChild(card);
      });
    }

    document.getElementById("searchInput").addEventListener("input", renderProducts);
    document.getElementById("categoryFilter").addEventListener("change", renderProducts);
    document.getElementById("storeFilter").addEventListener("change", renderProducts);

    const guides = {
      phone: {
        title: "Τι να προσέξεις πριν αγοράσεις μεταχειρισμένο κινητό",
        intro: "Πριν αγοράσεις κινητό, έλεγξε τα βασικά για να μη βρεθείς με ακριβό πρόβλημα.",
        points: [
          ["Μπαταρία", "Σε iPhone ζήτησε battery health. Κάτω από 80% σημαίνει πιθανή αλλαγή."],
          ["Οθόνη", "Έλεγξε αφή, φωτεινότητα, pixels και σπασίματα."],
          ["Κλείδωμα", "Βεβαιώσου ότι δεν είναι κλειδωμένο σε iCloud ή Google account."],
          ["Εγγύηση", "Αν υπάρχει εγγύηση, μειώνεται το ρίσκο."]
        ]
      },
      laptop: {
        title: "Laptop για δουλειά μέχρι 400€",
        intro: "Για καθημερινή χρήση, θες σωστά βασικά και όχι εντυπωσιακό κουτί.",
        points: [
          ["SSD", "Προτίμησε SSD. Ο παλιός HDD θα σε κάνει να γερνάς περιμένοντας."],
          ["RAM", "8GB RAM είναι το ελάχιστο για αξιοπρεπή χρήση."],
          ["Οθόνη", "Έλεγξε σημάδια, φωτεινότητα και πληκτρολόγιο."],
          ["Φορτιστής", "Να υπάρχει αξιόπιστος φορτιστής."]
        ]
      },
      refurbished: {
        title: "Refurbished ή μεταχειρισμένο;",
        intro: "Το refurbished δίνει συνήθως περισσότερη ασφάλεια. Το μεταχειρισμένο μπορεί να είναι φθηνότερο.",
        points: [
          ["Refurbished", "Συνήθως έχει έλεγχο και εγγύηση."],
          ["Μεταχειρισμένο", "Εξαρτάται από τον πωλητή και την κατάσταση."],
          ["Τιμή", "Αν η διαφορά είναι μικρή, το refurbished συχνά αξίζει περισσότερο."]
        ]
      }
    };

    function openGuide(type) {
      const guide = guides[type];
      const content = document.getElementById("guideContent");

      content.innerHTML = `
        <p class="text-blue-600 font-black uppercase tracking-widest text-sm">Οδηγός Gadgetora</p>
        <h2 class="text-3xl md:text-4xl font-black mt-2 pr-10">${guide.title}</h2>
        <p class="text-slate-600 mt-4 text-lg">${guide.intro}</p>
        <div class="mt-6 space-y-4">
          ${guide.points.map(item => `
            <div class="bg-slate-50 border border-slate-200 rounded-3xl p-5">
              <h3 class="font-black text-xl">${item[0]}</h3>
              <p class="text-slate-700 mt-2">${item[1]}</p>
            </div>
          `).join("")}
        </div>
      `;

      document.getElementById("guideModal").classList.remove("hidden");
      document.getElementById("guideModal").classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    function closeGuide() {
      document.getElementById("guideModal").classList.add("hidden");
      document.getElementById("guideModal").classList.remove("flex");
      document.body.style.overflow = "";
    }

    document.getElementById("askForm").addEventListener("submit", function(event) {
      event.preventDefault();

      const budget = document.getElementById("budget").value.trim();
      const deviceType = document.getElementById("deviceType").value;
      const usage = document.getElementById("usage").value.trim();

      const subject = encodeURIComponent("Gadgetora - Θέλω πρόταση αγοράς");
      const body = encodeURIComponent(
        "Θέλω πρόταση αγοράς από το Gadgetora\n\n" +
        "Budget: " + budget + "\n" +
        "Τύπος συσκευής: " + deviceType + "\n" +
        "Χρήση:\n" + usage + "\n\n"
      );

      window.location.href = "mailto:" + ADMIN_EMAIL + "?subject=" + subject + "&body=" + body;
      document.getElementById("askMessage").textContent = "Άνοιξε το email για να σταλεί το αίτημα.";
    });

    loadData();
  </script>
</body>
</html>
