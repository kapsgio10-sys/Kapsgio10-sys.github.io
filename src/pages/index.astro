<!DOCTYPE html>
<html lang="el" class="scroll-pt-24">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <meta name="google-site-verification" content="WrE052B6h1wSasuTdaF3emFy8EsunrBpYzzl0sj1p_w" />

  <title>Gadgetora | Οδηγοί αγοράς & σύγκριση τιμών για tech</title>
  <meta name="description" content="Gadgetora - Οδηγοί αγοράς για κινητά, laptop, tablets και refurbished tech. Σύγκρινε επιλογές και δες πραγματικές τιμές." />
  <meta name="keywords" content="μεταχειρισμένα κινητά, refurbished κινητά, laptop, σύγκριση τιμών, οδηγοί αγοράς" />
  <meta name="robots" content="index, follow" />

  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    html { scroll-behavior: smooth; }
    body { -webkit-font-smoothing: antialiased; }
    .glass {
      background: rgba(15, 23, 42, 0.86);
      backdrop-filter: blur(18px);
    }
    .soft-shadow {
      box-shadow: 0 24px 80px rgba(15, 23, 42, 0.14);
    }
    .card-hover {
      transition: all .3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .card-hover:hover {
      transform: translateY(-6px);
      box-shadow: 0 30px 60px rgba(15, 23, 42, 0.2);
    }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
</head>

<body class="bg-slate-950 text-white font-sans">

  <header class="sticky top-0 z-50 glass border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between gap-4">
      <a href="#top" class="flex items-center gap-3 shrink-0 group">
        <div class="w-11 h-11 rounded-2xl bg-blue-600 grid place-items-center font-black text-xl group-hover:scale-105 transition-transform">G</div>
        <div>
          <h1 class="font-black text-xl leading-none">Gadgetora</h1>
          <p class="text-xs text-slate-400">Tech Buying Guides</p>
        </div>
      </a>

      <nav class="flex overflow-x-auto items-center gap-4 md:gap-8 text-sm font-medium text-slate-400 pb-1 md:pb-0 scrollbar-hide w-full md:w-auto">
        <a href="#products" class="hover:text-white transition-colors whitespace-nowrap">Προϊόντα</a>
        <a href="#guides" class="hover:text-white transition-colors whitespace-nowrap">Οδηγοί</a>
        <a href="#checks" class="hover:text-white transition-colors whitespace-nowrap">Έλεγχοι</a>
        <a href="#ask" class="hover:text-white transition-colors whitespace-nowrap">Ρώτα μας</a>
      </nav>

      <a href="#products" class="hidden md:block bg-white text-slate-950 px-5 py-2.5 rounded-xl font-bold text-sm shrink-0 hover:bg-blue-50 transition-colors">
        Δες επιλογές
      </a>
    </div>
  </header>

  <section id="top" class="relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(37,99,235,.25),_transparent_40%),radial-gradient(circle_at_bottom_right,_rgba(16,185,129,.15),_transparent_40%)]"></div>

    <div class="relative max-w-7xl mx-auto px-4 py-16 md:py-28 grid lg:grid-cols-2 gap-12 items-center">
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-blue-300 mb-8">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          Αξιόπιστες προτάσεις & έλεγχος τιμών
        </div>

        <h2 class="text-5xl md:text-7xl font-black leading-tight tracking-tight">
          Βρες τι αξίζει να <span class="text-blue-500">αγοράσεις.</span>
        </h2>

        <p class="mt-8 text-xl text-slate-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
          Αναλύουμε την αγορά για να μη χρειάζεται να το κάνεις εσύ. Βρες πραγματικές τιμές και έξυπνες επιλογές για την επόμενη tech αγορά σου.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="#products" class="bg-blue-600 hover:bg-blue-500 px-8 py-4 rounded-2xl font-black text-lg transition-all shadow-lg shadow-blue-600/20">
            Δες προϊόντα
          </a>
          <a href="#guides" class="bg-white/10 hover:bg-white/20 border border-white/10 px-8 py-4 rounded-2xl font-black text-lg transition-all">
            Οδηγοί αγοράς
          </a>
        </div>
      </div>

      <div class="bg-white text-slate-950 rounded-[2.5rem] p-4 soft-shadow">
        <!-- Optimized Hero Image -->
        <img
          src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1000&q=75"
          alt="Tech setup"
          class="w-full h-80 object-cover rounded-[2rem] mb-8"
        />
        <div class="px-4 pb-6">
          <p class="text-sm text-blue-600 font-black uppercase tracking-widest mb-2">Η Φιλοσοφία μας</p>
          <h3 class="text-3xl font-black">Διαφάνεια πάνω από όλα.</h3>
          <p class="text-slate-600 mt-4 leading-relaxed text-lg">
            Δεν προτείνουμε απλώς προϊόντα. Ελέγχουμε την αξιοπιστία των πωλητών σε Skroutz, BestPrice και Amazon για να είσαι σίγουρος.
          </p>
        </div>
      </div>
    </div>
  </section>

  <main class="bg-slate-50 text-slate-950">
    <section id="products" class="max-w-7xl mx-auto px-4 py-20">
      <div class="mb-12">
        <p class="text-blue-600 font-black uppercase tracking-widest text-sm">Real-time Data</p>
        <h2 class="text-4xl md:text-5xl font-black mt-2">Επιλογές & Τιμές</h2>
      </div>

      <div class="bg-white border border-slate-200 rounded-3xl p-4 mb-12 grid md:grid-cols-3 gap-4 shadow-sm">
        <input id="searchInput" class="rounded-xl border border-slate-200 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-500 transition-all bg-slate-50" placeholder="Αναζήτηση..." />
        <select id="categoryFilter" class="rounded-xl border border-slate-200 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-500 transition-all bg-slate-50 cursor-pointer">
          <option value="all">Όλες οι κατηγορίες</option>
          <option value="Κινητά">Κινητά</option>
          <option value="Laptop">Laptop</option>
          <option value="Refurbished">Refurbished</option>
        </select>
        <select id="storeFilter" class="rounded-xl border border-slate-200 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-500 transition-all bg-slate-50 cursor-pointer">
          <option value="all">Όλα τα καταστήματα</option>
          <option value="Skroutz">Skroutz</option>
          <option value="BestPrice">BestPrice</option>
          <option value="Amazon">Amazon</option>
        </select>
      </div>

      <div id="productGrid" class="grid md:grid-cols-3 gap-8 items-stretch"></div>

      <div id="noProducts" class="hidden bg-white border border-slate-200 rounded-[2rem] p-12 text-center soft-shadow">
        <div class="text-5xl mb-4">🔍</div>
        <h3 class="text-2xl font-black">Δεν βρήκαμε αυτό που ψάχνεις</h3>
        <p class="text-slate-500 mt-2">Δοκίμασε διαφορετικά φίλτρα ή λέξεις-κλειδιά.</p>
      </div>
    </section>

    <!-- Optimized Guide Images -->
    <section id="guides" class="max-w-7xl mx-auto px-4 py-20 border-t border-slate-200">
      <h2 class="text-4xl font-black mb-10">Οδηγοί Αγοράς</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <article class="bg-white rounded-3xl overflow-hidden border border-slate-200 card-hover flex flex-col">
          <img src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?auto=format&fit=crop&w=600&q=70" class="h-48 w-full object-cover" alt="Phone guide">
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-2xl font-black">Οδηγός Κινητού</h3>
            <p class="text-slate-600 mt-3 flex-grow text-sm">Μπαταρία, οθόνη και έλεγχος κλειδώματος iCloud/Google.</p>
            <button onclick="openGuide('phone')" class="mt-6 w-full bg-slate-900 text-white rounded-xl py-3 font-bold hover:bg-blue-600 transition-colors">Άνοιγμα</button>
          </div>
        </article>

        <article class="bg-white rounded-3xl overflow-hidden border border-slate-200 card-hover flex flex-col">
          <img src="https://images.unsplash.com/photo-1517336714731-489689fd1ca8?auto=format&fit=crop&w=600&q=70" class="h-48 w-full object-cover" alt="Laptop guide">
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-2xl font-black">Laptop έως 400€</h3>
            <p class="text-slate-600 mt-3 flex-grow text-sm">SSD και RAM: Τα δύο πράγματα που θα κάνουν τη διαφορά.</p>
            <button onclick="openGuide('laptop')" class="mt-6 w-full bg-slate-900 text-white rounded-xl py-3 font-bold hover:bg-blue-600 transition-colors">Άνοιγμα</button>
          </div>
        </article>

        <article class="bg-white rounded-3xl overflow-hidden border border-slate-200 card-hover flex flex-col">
          <img src="https://images.unsplash.com/photo-1642132652860-471b4228023e?auto=format&fit=crop&w=600&q=70" class="h-48 w-full object-cover" alt="Refurbished guide">
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-2xl font-black">Refurbished</h3>
            <p class="text-slate-600 mt-3 flex-grow text-sm">Πότε η εγγύηση αξίζει τα παραπάνω χρήματα.</p>
            <button onclick="openGuide('refurbished')" class="mt-6 w-full bg-slate-900 text-white rounded-xl py-3 font-bold hover:bg-blue-600 transition-colors">Άνοιγμα</button>
          </div>
        </article>
      </div>
    </section>
  </main>

  <!-- Modal Code (id=guideModal) and Scripts remain same structure but with minor UX cleanups -->
  <!-- ... (id="checks", id="ask" etc) ... -->

  <div id="guideModal" class="fixed inset-0 bg-slate-900/90 z-[100] hidden items-center justify-center p-4 backdrop-blur-sm">
    <div class="bg-white text-slate-950 rounded-3xl max-w-2xl w-full max-h-[80vh] overflow-y-auto p-8 relative shadow-2xl">
      <button onclick="closeGuide()" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-slate-100 font-black hover:bg-slate-200 transition-colors">×</button>
      <div id="guideContent"></div>
    </div>
  </div>

  <script>
    const ADMIN_EMAIL = "kapsgio10@gmail.com";
    let products = [];
    let priceData = {};

    // Load Data
    async function loadData() {
      try {
        const [pRes, prRes] = await Promise.all([
          fetch("./products.json?ts=" + Date.now()),
          fetch("./prices.json?ts=" + Date.now())
        ]);
        const pJson = await pRes.json();
        const prJson = await prRes.json();
        products = pJson.products || [];
        priceData = prJson.prices || {};
        document.getElementById("lastUpdated").textContent = "Ενημέρωση: " + (prJson.updated_at || "Σήμερα");
        renderProducts();
      } catch (e) {
        document.getElementById("productGrid").innerHTML = "<p class='col-span-full text-center py-10'>Πρόβλημα φόρτωσης. Δοκίμασε ξανά.</p>";
      }
    }

    function renderProducts() {
      const q = document.getElementById("searchInput").value.toLowerCase();
      const cat = document.getElementById("categoryFilter").value;
      const stor = document.getElementById("storeFilter").value;

      const filtered = products.filter(p => {
        const matchesSearch = p.title.toLowerCase().includes(q) || p.description.toLowerCase().includes(q);
        const matchesCat = cat === "all" || p.category === cat;
        const matchesStore = stor === "all" || p.store === stor;
        return matchesSearch && matchesCat && matchesStore;
      });

      const grid = document.getElementById("productGrid");
      grid.innerHTML = "";
      document.getElementById("noProducts").classList.toggle("hidden", filtered.length > 0);

      filtered.forEach(p => {
        const info = priceData[p.id] || { price: "Δες στο site", store: p.store };
        grid.innerHTML += `
          <article class="bg-white rounded-3xl p-5 border border-slate-200 soft-shadow card-hover flex flex-col">
            <img src="${p.image}?auto=format&fit=crop&w=500&q=70" class="h-44 w-full object-cover rounded-2xl mb-4" alt="${p.title}">
            <div class="flex-grow">
              <span class="text-blue-600 text-[10px] font-black uppercase tracking-widest">${p.category}</span>
              <h3 class="text-xl font-black mt-1 leading-tight">${p.title}</h3>
              <p class="text-slate-500 text-sm mt-3 leading-relaxed">${p.description}</p>
            </div>
            <div class="mt-6 pt-4 border-t border-slate-100">
              <div class="flex justify-between items-end mb-4">
                <div>
                  <p class="text-[10px] text-slate-400 uppercase font-bold">Τιμή</p>
                  <p class="text-xl font-black text-slate-900">${info.price}</p>
                </div>
                <p class="text-[10px] bg-slate-100 px-2 py-1 rounded font-bold">${info.store}</p>
              </div>
              <a href="${p.affiliate_url}" target="_blank" rel="noopener" class="block w-full bg-blue-600 text-white text-center py-3 rounded-xl font-bold hover:bg-blue-700 transition-colors">Περισσότερα</a>
            </div>
          </article>
        `;
      });
    }

    // Listeners
    document.getElementById("searchInput").addEventListener("input", renderProducts);
    document.getElementById("categoryFilter").addEventListener("change", renderProducts);
    document.getElementById("storeFilter").addEventListener("change", renderProducts);

    function openGuide(type) { /* Ίδιος κώδικας logic */ }
    function closeGuide() { document.getElementById("guideModal").classList.add("hidden"); document.body.style.overflow = ""; }

    loadData();
  </script>
</body>
</html>
