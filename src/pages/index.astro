        store: "Amazon",
        description: "Αναζήτηση refurbished smartphones στο Amazon.",
        image: "https://images.unsplash.com/photo-1603791440384-56cd371ee9a7?auto=format&fit=crop&w=900&q=80",
        affiliate_url: "https://www.amazon.de/s?k=refurbished+smartphone"
      }
    ];

    const fallbackPrices = {
      phones_general: { price: "Δες σημερινές τιμές στο Skroutz", store: "Skroutz" },
      phones_bestprice: { price: "Δες σημερινές τιμές στο BestPrice", store: "BestPrice" },
      laptop_general: { price: "Δες σημερινές τιμές στο Skroutz", store: "Skroutz" },
      laptop_bestprice: { price: "Δες σημερινές τιμές στο BestPrice", store: "BestPrice" },
      refurbished_general: { price: "Δες refurbished τιμές στο Skroutz", store: "Skroutz" },
      refurbished_amazon: { price: "Δες refurbished τιμές στο Amazon", store: "Amazon" }
    };

    let products = [];
    let priceData = {};

    function escapeHTML(value) {
      return String(value || "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    async function safeJsonFetch(path) {
      const response = await fetch(path + "?ts=" + Date.now());
      if (!response.ok) throw new Error("Fetch failed: " + path);
      return response.json();
    }

    async function loadData() {
      try {
        const [productsJson, pricesJson] = await Promise.all([
          safeJsonFetch("./products.json"),
          safeJsonFetch("./prices.json")
        ]);

        products = Array.isArray(productsJson.products) ? productsJson.products : fallbackProducts;
        priceData = pricesJson.prices || fallbackPrices;

        const updated = document.getElementById("lastUpdated");
        if (updated) {
          updated.textContent = "Τελευταία ενημέρωση τιμών: " + (pricesJson.updated_at || "Σήμερα");
        }
      } catch (error) {
        products = fallbackProducts;
        priceData = fallbackPrices;

        const updated = document.getElementById("lastUpdated");
        if (updated) {
          updated.textContent = "Τελευταία ενημέρωση τιμών: βασικές προτάσεις Gadgetora";
        }
      }

      renderProducts();
    }

    function getPriceInfo(productId, fallbackStore) {
      return priceData[productId] || {
        price: "Δες σημερινή τιμή",
        store: fallbackStore || "-"
      };
    }

    function renderProducts() {
      const query = document.getElementById("searchInput").value.toLowerCase().trim();
      const category = document.getElementById("categoryFilter").value;
      const store = document.getElementById("storeFilter").value;

      const filtered = products.filter(product => {
        const text = [
          product.title,
          product.category,
          product.description,
          product.store
        ].join(" ").toLowerCase();

        const matchesSearch = !query || text.includes(query);
        const matchesCategory = category === "all" || product.category === category;
        const matchesStore = store === "all" || product.store === store;

        return matchesSearch && matchesCategory && matchesStore;
      });

      const grid = document.getElementById("productGrid");
      const noProducts = document.getElementById("noProducts");

      grid.innerHTML = "";
      noProducts.classList.toggle("hidden", filtered.length !== 0);

      filtered.forEach(product => {
        const info = getPriceInfo(product.id, product.store);
        const card = document.createElement("article");

        card.className = "bg-white rounded-[2rem] p-6 border border-slate-200 soft-shadow card-hover flex flex-col";

        card.innerHTML = `
          <img src="${escapeHTML(product.image)}" alt="${escapeHTML(product.title)}" class="h-44 w-full object-cover rounded-3xl mb-5">
          <p class="text-blue-600 text-xs font-black uppercase tracking-widest">${escapeHTML(product.category)}</p>
          <h3 class="text-2xl font-black mt-2">${escapeHTML(product.title)}</h3>
          <p class="text-slate-600 mt-3 flex-1">${escapeHTML(product.description)}</p>

          <div class="mt-5 rounded-2xl bg-slate-100 p-4">
            <p class="text-xs text-slate-500 mb-1">Τρέχουσα τιμή / Διαθεσιμότητα</p>
            <p class="text-base font-bold text-slate-800 leading-tight">${escapeHTML(info.price)}</p>
            <p class="text-xs text-slate-500 mt-2 border-t border-slate-200 pt-2">Πηγή: ${escapeHTML(info.store || product.store)}</p>
          </div>

          <a
            target="_blank"
            rel="noopener"
            href="${escapeHTML(product.affiliate_url)}"
            class="mt-5 block w-full bg-slate-950 hover:bg-blue-600 text-white rounded-2xl px-5 py-3 font-black text-center"
          >
            Δες επιλογές
          </a>
        `;

        grid.appendChild(card);
      });
    }

    document.getElementById("searchInput").addEventListener("input", renderProducts);
    document.getElementById("categoryFilter").addEventListener("change", renderProducts);
    document.getElementById("storeFilter").addEventListener("change", renderProducts);

    const guides = {
      phone: {
        title: "Τι να προσέξεις πριν αγοράσεις μεταχειρισμένο κινητό",
        intro: "Πριν αγοράσεις κινητό, έλεγξε τα βασικά για να μη βρεθείς με ακριβό πρόβλημα.",
        points: [
          ["Μπαταρία", "Σε iPhone ζήτησε battery health. Κάτω από 80% σημαίνει πιθανή αλλαγή. Σε Android έλεγξε διάρκεια χρήσης και φόρτιση."],
          ["Οθόνη", "Έλεγξε αφή, φωτεινότητα, pixels, σκιές, γραμμές και αν η οθόνη έχει αλλαχθεί."],
          ["Κλείδωμα", "Βεβαιώσου ότι δεν είναι κλειδωμένο σε iCloud ή Google account. Χωρίς αυτό, αγοράζεις διακοσμητικό τούβλο."],
          ["Εγγύηση", "Αν υπάρχει εγγύηση, μειώνεται το ρίσκο. Σε refurbished είναι από τα πιο σημαντικά σημεία."],
          ["Τελική τιμή", "Σύγκρινε τιμή με καινούργιο ή refurbished. Αν η διαφορά είναι μικρή, το μεταχειρισμένο δεν αξίζει."]
        ]
      },
      laptop: {
        title: "Laptop για δουλειά μέχρι 400€",
        intro: "Για καθημερινή χρήση, θες σωστά βασικά και όχι εντυπωσιακό κουτί που σέρνεται.",
        points: [
          ["SSD", "Προτίμησε SSD. Ο παλιός HDD θα σε κάνει να γερνάς περιμένοντας να ανοίξει ο browser."],
          ["RAM", "8GB RAM είναι το ελάχιστο για αξιοπρεπή χρήση. 16GB είναι καλύτερα αν κάνεις πολλά πράγματα μαζί."],
          ["Οθόνη", "Έλεγξε φωτεινότητα, γραμμές, σπασίματα και αν κουράζει στα μάτια."],
          ["Μπαταρία", "Μη βασίζεσαι στα λόγια του πωλητή. Ζήτα πραγματική διάρκεια ή έλεγχο κύκλων."],
          ["Φορτιστής", "Να υπάρχει αξιόπιστος φορτιστής. Οι φθηνοί άγνωστοι φορτιστές είναι μικρά ηλεκτρικά λαχεία."]
        ]
      },
      refurbished: {
        title: "Refurbished ή μεταχειρισμένο;",
        intro: "Το refurbished δίνει συνήθως περισσότερη ασφάλεια. Το μεταχειρισμένο μπορεί να είναι φθηνότερο αλλά έχει περισσότερο ρίσκο.",
        points: [
          ["Refurbished", "Συνήθως έχει έλεγχο, καθάρισμα, πιθανή αλλαγή ανταλλακτικών και εγγύηση."],
          ["Μεταχειρισμένο", "Μπορεί να βγει φθηνότερο, αλλά πρέπει να ελέγξεις τα πάντα μόνος σου."],
          ["Εγγύηση", "Αν αγοράζεις ακριβή συσκευή, η εγγύηση αξίζει παραπάνω από μια μικρή έκπτωση."],
          ["Κατάσταση", "Δες βαθμίδα κατάστασης, σημάδια χρήσης, μπαταρία και πολιτική επιστροφής."],
          ["Τελική επιλογή", "Για κινητά και laptop δουλειάς, refurbished με εγγύηση είναι συχνά η πιο ήρεμη λύση."]
        ]
      }
    };

    function openGuide(type) {
      const guide = guides[type];
      if (!guide) return;

      const modal = document.getElementById("guideModal");
      const content = document.getElementById("guideContent");

      content.innerHTML = `
        <p class="text-blue-600 font-black uppercase tracking-widest text-sm">Οδηγός Gadgetora</p>
        <h2 class="text-3xl md:text-4xl font-black mt-2 pr-10">${escapeHTML(guide.title)}</h2>
        <p class="text-slate-600 mt-4 leading-relaxed">${escapeHTML(guide.intro)}</p>

        <div class="mt-6 grid gap-4">
          ${guide.points.map(point => `
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <h3 class="font-black text-lg">${escapeHTML(point[0])}</h3>
              <p class="text-slate-600 mt-2">${escapeHTML(point[1])}</p>
            </div>
          `).join("")}
        </div>

        <button type="button" onclick="closeGuide()" class="mt-6 w-full bg-slate-950 text-white rounded-2xl px-5 py-3 font-black hover:bg-blue-600">
          Κλείσιμο οδηγού
        </button>
      `;

      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    function closeGuide() {
      const modal = document.getElementById("guideModal");
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      document.body.style.overflow = "";
    }

    document.getElementById("guideModal").addEventListener("click", event => {
      if (event.target.id === "guideModal") closeGuide();
    });

    document.addEventListener("keydown", event => {
      if (event.key === "Escape") closeGuide();
    });

    document.getElementById("askForm").addEventListener("submit", event => {
      event.preventDefault();

      const budget = document.getElementById("budget").value.trim();
      const deviceType = document.getElementById("deviceType").value;
      const usage = document.getElementById("usage").value.trim();

      const subject = "Αίτημα πρότασης αγοράς από Gadgetora";
      const body = [
        "Γεια σου Gadgetora,",
        "",
        "Θέλω πρόταση αγοράς.",
        "",
        "Budget: " + budget,
        "Τύπος συσκευής: " + deviceType,
        "Χρήση: " + usage,
        "",
        "Ευχαριστώ."
      ].join("\n");

      const mailto = "mailto:" + ADMIN_EMAIL
        + "?subject=" + encodeURIComponent(subject)
        + "&body=" + encodeURIComponent(body);

      document.getElementById("askMessage").textContent = "Άνοιξε το email σου με έτοιμο μήνυμα. Έλεγξέ το και στείλ' το.";
      window.location.href = mailto;
    });

    loadData();
  </script>
</body>
</html>
